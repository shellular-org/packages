{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "Node16",
		"moduleResolution": "node16",
		"ignoreDeprecations": "5.0",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"types": ["node", "vscode"],
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
